# Template for Streamlit secrets.
# Local dev: copy to `.streamlit/secrets.toml` (gitignored) — only app_password is needed,
# since the corpus + preview load from local data/.
# Deploy (Streamlit Community Cloud): paste these into the app's Secrets manager.

# The shared gate password.
app_password = "change-me"

# --- Deploy-only: lets the app fetch the gitignored corpus + preview PDF at startup
# --- from the PRIVATE manual repo (so neither file ever lives in this public repo).
# github_token  = "github_pat_xxx"                 # fine-grained PAT, read-only Contents on the manual repo
# manual_repo   = "BuffaloHat/soapy-ai-field-manual"
# manual_branch = "main"                           # optional (default: main)
# corpus_path   = "build/manuscript_review.md"     # optional (default shown)
# preview_path  = "build/manual_preview.pdf"       # optional (default shown)
